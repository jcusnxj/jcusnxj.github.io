{% set navPages = collections.all | eleventyNavigationBreadcrumb(eleventyNavigation.key, { includeSelf: true }) %}
{% for crumb in navPages %}

{% if loop.first %}
<nav class="bredcrumb">
{% endif %}

        {% if not loop.last %}
            <a href="{{ crumb.url }}" class="crumb">{{ crumb.key }}</a>
            
        {% else %}
        {% if page.url == "/" %}
        
            <div class="crumb-last">Fuck it, dude. Let's go running.</div>
 
        {% else %}
            <div class="crumb-last">{{ crumb.key }}</div>
        {% endif %}
    
</nav>
{% endif %}
{% endfor %}